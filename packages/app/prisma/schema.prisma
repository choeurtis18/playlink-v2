datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("editor") // editor | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Game {
  id             String     @id @default(cuid())
  name           String     @unique
  slug           String     @unique
  description    String?
  icon           String?
  colorMain      String
  colorSecondary String
  active         Boolean    @default(true)
  order          Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  categories  Category[]
  rules       GameRules?
  ruleSlides  GameRuleSlide[]

  @@map("games")
}

model GameRules {
  id        String   @id @default(cuid())
  gameId    String   @unique
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rules     String
  updatedAt DateTime @updatedAt

  @@map("game_rules")
}

model GameRuleSlide {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  imageUrl  String?
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("game_rule_slides")
}

model Category {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards Card[]

  @@unique([gameId, slug])
  @@map("categories")
}

model Card {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  text       String
  difficulty String?  // easy | medium | hard
  tags       String[]
  active     Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("cards")
}

model AppUser {
  id         String      @id @default(cuid())
  supabaseId String      @unique
  email      String      @unique
  firstName  String?
  lastName   String?
  players    Player[]
  badges     UserBadge[]
  createdAt  DateTime    @default(now())

  @@map("app_users")
}

model Player {
  id          String              @id @default(cuid())
  name        String
  avatar      String?
  appUserId   String
  appUser     AppUser             @relation(fields: [appUserId], references: [id])
  tagScores   Json                @default("{}")
  sessions    GameSessionPlayer[]
  createdAt   DateTime            @default(now())

  @@map("players")
}

model GameSession {
  id         String              @id @default(cuid())
  gameId     String
  categoryId String
  status     String              @default("finished")
  players    GameSessionPlayer[]
  createdAt  DateTime            @default(now())

  @@map("game_sessions")
}

model GameSessionPlayer {
  id              String      @id @default(cuid())
  sessionId       String
  session         GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId        String
  player          Player      @relation(fields: [playerId], references: [id])
  score           Int         @default(0)
  tagScoresGained Json        @default("{}")

  @@unique([sessionId, playerId])
  @@map("game_session_players")
}

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  icon        String
  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([appUserId, badgeId])
  @@map("user_badges")
}

model LegalContent {
  id        String   @id @default(cuid())
  key       String   @unique // privacy | terms
  title     String
  content   String
  updatedAt DateTime @updatedAt

  @@map("legal_contents")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // created_card | updated_card | deleted_card | etc
  entity    String   // card | category | game
  entityId  String
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Event {
  id         String   @id @default(cuid())
  type       String   // game_started | card_viewed | game_finished
  gameId     String?
  categoryId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([gameId])
  @@index([createdAt])
  @@map("events")
}
